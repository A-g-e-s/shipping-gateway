{
    "name": "ages/shipping-gateway",
    "description": "Unified shipping carrier API for CzechPost, GLS, PPL",
    "type": "library",
    "require": {
        "php": ">=8.4",
        "guzzlehttp/guzzle": "^7.9",
        "tracy/tracy": "^2.8",
        "nette/utils": "^4.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ages\\ShippingGateway\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "phpstan": "phpstan analyse"
    }
}
